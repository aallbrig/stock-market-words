{
  "name": "stock-market-words",
  "version": "1.0.0",
  "description": "Why? Why not. I remembered reading about how linux has a file with a dictionary in it.",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:perf": "jest tests/perf/",
    "test:e2e:ci": "playwright test",
    "test:e2e:qa": "TEST_URL=https://stockmarketwords.com/ NO_AUTO_SERVER=true playwright test",
    "test:status": "node tests/cli/test-status.js",
    "profile": "node --prof node_modules/.bin/jest tests/perf/ && echo '\nProfile generated! Process with: node --prof-process isolate-*.log > profile.txt'",
    "test:pw": "playwright test",
    "test:pw:ui": "playwright test --ui",
    "test:pw:debug": "playwright test --debug",
    "test:pw:headed": "playwright test --headed",
    "test:pw:codegen": "playwright codegen http://localhost:1313",
    "test:pw:report": "playwright show-report test-reports/playwright",
    "test:pw:pages": "playwright test website-pages",
    "test:pw:ticker": "playwright test ticker-ui",
    "test:pw:datatables": "playwright test datatables",
    "test:pw:qa": "TEST_URL=https://stockmarketwords.com/ NO_AUTO_SERVER=true playwright test"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 90000,
    "silent": false,
    "verbose": false,
    "reporters": [
      "default",
      "./tests/reporters/test-results-reporter.js",
      [
        "jest-html-reporter",
        {
          "pageTitle": "Stock Market Words Test Report",
          "outputPath": "test-reports/index.html",
          "includeFailureMsg": true,
          "includeConsoleLog": false,
          "theme": "darkTheme",
          "sort": "status"
        }
      ],
      [
        "jest-junit",
        {
          "outputDirectory": "test-reports",
          "outputName": "junit.xml",
          "classNameTemplate": "{classname}",
          "titleTemplate": "{title}",
          "ancestorSeparator": " › ",
          "usePathForSuiteName": true
        }
      ]
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aallbrig/stock-market-words.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/aallbrig/stock-market-words/issues"
  },
  "homepage": "https://github.com/aallbrig/stock-market-words#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "jest-html-reporter": "^4.3.0",
    "jest-junit": "^16.0.0"
  }
}
