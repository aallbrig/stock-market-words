{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ticker_lookup.schema.json",
  "title": "ticker-lookup.json",
  "description": "Minimal symbol+name pairs for client-side autocomplete. Uses short keys ('s', 'n') to minimise payload size. Generated by hugo_generators.py::generate_ticker_lookup_json().",
  "type": "object",
  "required": ["_meta", "total", "tickers"],
  "additionalProperties": false,
  "properties": {
    "_meta": {
      "type": "object",
      "required": ["auto_generated", "generated_by", "generated_at", "warning"],
      "additionalProperties": false,
      "properties": {
        "auto_generated": { "type": "boolean", "const": true },
        "generated_by":   { "type": "string" },
        "generated_at":   { "type": "string", "format": "date-time" },
        "warning":        { "type": "string" }
      }
    },
    "total": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of entries in the tickers array"
    },
    "tickers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["s", "n"],
        "additionalProperties": false,
        "properties": {
          "s": { "type": "string", "minLength": 1, "description": "Ticker symbol" },
          "n": { "type": "string", "description": "Company name (empty string if name is null in DB)" }
        }
      }
    }
  }
}
