{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "metadata.schema.json",
  "title": "metadata.json",
  "description": "Full ticker reference data keyed by symbol for O(1) browser lookup. Richer than strategy files: includes financial health, growth, and analyst fields. Note: scores always present as integers (never null) for the 5 base strategies; reitRadar is omitted entirely. Generated by builders.py::build_assets().",
  "type": "object",
  "additionalProperties": { "$ref": "#/$defs/tickerMetadata" },
  "propertyNames": {
    "type": "string",
    "minLength": 1,
    "description": "Ticker symbol"
  },
  "$defs": {
    "scores": {
      "type": "object",
      "required": ["dividendDaddy", "moonShot", "fallingKnife", "overHyped", "instWhale"],
      "additionalProperties": false,
      "description": "Percentile ranks 1–100. Always integers (never null). reitRadar is excluded — it is only computed for REITs and stored in strategy_reit_radar.json.",
      "properties": {
        "dividendDaddy": { "type": "integer", "minimum": 1, "maximum": 100 },
        "moonShot":      { "type": "integer", "minimum": 1, "maximum": 100 },
        "fallingKnife":  { "type": "integer", "minimum": 1, "maximum": 100 },
        "overHyped":     { "type": "integer", "minimum": 1, "maximum": 100 },
        "instWhale":     { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "tickerMetadata": {
      "type": "object",
      "required": [
        "name", "exchange", "sector", "industry",
        "price", "volume", "marketCap",
        "dividendYield", "beta", "rsi", "ma200", "ma50",
        "peRatio", "forwardPE", "priceToBook", "pegRatio", "enterpriseValue",
        "week52High", "week52Low",
        "avgVolume10Day",
        "shortRatio", "shortPercentFloat",
        "debtToEquity", "currentRatio", "quickRatio",
        "profitMargin", "operatingMargin", "returnOnEquity", "returnOnAssets",
        "revenueGrowth", "earningsGrowth",
        "targetMeanPrice", "recommendationMean", "numAnalystOpinions",
        "sharesOutstanding", "floatShares",
        "scores"
      ],
      "additionalProperties": false,
      "properties": {
        "name":     { "type": ["string", "null"] },
        "exchange": { "type": ["string", "null"] },
        "sector":   { "type": ["string", "null"] },
        "industry": { "type": ["string", "null"] },

        "price":    { "type": "number" },
        "volume":   { "type": "integer", "minimum": 0 },

        "marketCap":       { "type": ["integer", "null"], "minimum": 0 },
        "dividendYield":   { "type": ["number", "null"], "description": "Percentage (db decimal * 100)" },
        "beta":            { "type": ["number", "null"] },
        "rsi":             { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "ma200":           { "type": ["number", "null"], "minimum": 0 },
        "ma50":            { "type": ["number", "null"], "minimum": 0 },

        "peRatio":         { "type": ["number", "null"] },
        "forwardPE":       { "type": ["number", "null"] },
        "priceToBook":     { "type": ["number", "null"] },
        "pegRatio":        { "type": ["number", "null"] },
        "enterpriseValue": { "type": ["integer", "null"], "minimum": 0 },

        "week52High": { "type": ["number", "null"], "minimum": 0 },
        "week52Low":  { "type": ["number", "null"], "minimum": 0 },

        "avgVolume10Day": { "type": ["integer", "null"], "minimum": 0 },

        "shortRatio":        { "type": ["number", "null"], "minimum": 0 },
        "shortPercentFloat": { "type": ["number", "null"], "description": "Percentage (db decimal * 100)" },

        "debtToEquity":  { "type": ["number", "null"] },
        "currentRatio":  { "type": ["number", "null"], "minimum": 0 },
        "quickRatio":    { "type": ["number", "null"], "minimum": 0 },

        "profitMargin":    { "type": ["number", "null"], "description": "Percentage (db decimal * 100)" },
        "operatingMargin": { "type": ["number", "null"], "description": "Percentage (db decimal * 100)" },
        "returnOnEquity":  { "type": ["number", "null"], "description": "Percentage (db decimal * 100)" },
        "returnOnAssets":  { "type": ["number", "null"], "description": "Percentage (db decimal * 100)" },

        "revenueGrowth":  { "type": ["number", "null"], "description": "Percentage (db decimal * 100)" },
        "earningsGrowth": { "type": ["number", "null"], "description": "Percentage (db decimal * 100)" },

        "targetMeanPrice":    { "type": ["number", "null"], "minimum": 0 },
        "recommendationMean": { "type": ["number", "null"], "minimum": 1, "maximum": 5 },
        "numAnalystOpinions": { "type": ["integer", "null"], "minimum": 0 },

        "sharesOutstanding": { "type": ["integer", "null"], "minimum": 0 },
        "floatShares":       { "type": ["integer", "null"], "minimum": 0 },

        "scores": { "$ref": "#/$defs/scores" }
      }
    }
  }
}
