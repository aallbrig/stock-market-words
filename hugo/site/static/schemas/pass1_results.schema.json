{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "pass1_results.schema.json",
  "title": "pass1_results.json",
  "description": "Extraction progress summary: how many tickers got prices (pass 1) vs full metadata (pass 2). Generated by hugo_generators.py::generate_filtered_data().",
  "type": "object",
  "required": ["_meta", "generated_at", "date", "pass1_extraction", "pass2_extraction"],
  "additionalProperties": false,
  "properties": {
    "_meta": {
      "type": "object",
      "required": ["auto_generated", "generated_by", "generated_at", "warning"],
      "additionalProperties": false,
      "properties": {
        "auto_generated": { "type": "boolean", "const": true },
        "generated_by":   { "type": "string" },
        "generated_at":   { "type": "string", "format": "date-time" },
        "warning":        { "type": "string" }
      }
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "date":         { "type": "string", "format": "date" },
    "pass1_extraction": {
      "type": "object",
      "required": ["total_attempted", "successful", "failed", "success_rate"],
      "additionalProperties": false,
      "properties": {
        "total_attempted": { "type": "integer", "minimum": 0 },
        "successful":      { "type": "integer", "minimum": 0 },
        "failed":          { "type": "integer", "minimum": 0 },
        "success_rate":    { "type": "string", "pattern": "^\\d+\\.\\d+%$", "description": "Formatted as '95.6%'" }
      }
    },
    "pass2_extraction": {
      "type": "object",
      "required": ["total_attempted", "successful", "pending"],
      "additionalProperties": false,
      "properties": {
        "total_attempted": { "type": "integer", "minimum": 0 },
        "successful":      { "type": "integer", "minimum": 0 },
        "pending":         { "type": "integer", "minimum": 0 }
      }
    }
  }
}
