{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "strategy.schema.json",
  "title": "strategy_<key>.json",
  "description": "Per-strategy ticker list files: strategy_dividend_daddy.json, strategy_moon_shot.json, strategy_falling_knife.json, strategy_over_hyped.json, strategy_institutional_whale.json, strategy_reit_radar.json. Generated by hugo_generators.py::generate_strategy_filters().",
  "type": "object",
  "required": [
    "_meta", "strategy", "strategy_key", "description", "icon",
    "generated_at", "date", "total_matches", "filter_criteria", "tickers"
  ],
  "additionalProperties": false,
  "properties": {
    "_meta": {
      "type": "object",
      "required": ["auto_generated", "generated_by", "generated_at", "warning"],
      "additionalProperties": false,
      "properties": {
        "auto_generated": { "type": "boolean", "const": true },
        "generated_by":   { "type": "string" },
        "generated_at":   { "type": "string", "format": "date-time" },
        "warning":        { "type": "string" }
      }
    },
    "strategy":        { "type": "string", "description": "Human-readable strategy name, e.g. 'Dividend Daddy'" },
    "strategy_key":    {
      "type": "string",
      "enum": ["dividend_daddy", "moon_shot", "falling_knife", "over_hyped", "institutional_whale", "reit_radar"]
    },
    "description":     { "type": "string" },
    "icon":            { "type": "string" },
    "generated_at":    { "type": "string", "format": "date-time" },
    "date":            { "type": "string", "format": "date" },
    "total_matches":   { "type": "integer", "minimum": 0 },
    "filter_criteria": { "type": "string", "description": "Raw SQL WHERE clause fragment used to filter tickers" },
    "tickers": {
      "type": "array",
      "items": { "$ref": "#/$defs/ticker" }
    }
  },
  "$defs": {
    "scores": {
      "type": "object",
      "required": ["dividendDaddy", "moonShot", "fallingKnife", "overHyped", "instWhale", "reitRadar"],
      "additionalProperties": false,
      "properties": {
        "dividendDaddy": { "type": ["integer", "null"], "minimum": 1, "maximum": 100 },
        "moonShot":      { "type": ["integer", "null"], "minimum": 1, "maximum": 100 },
        "fallingKnife":  { "type": ["integer", "null"], "minimum": 1, "maximum": 100 },
        "overHyped":     { "type": ["integer", "null"], "minimum": 1, "maximum": 100 },
        "instWhale":     { "type": ["integer", "null"], "minimum": 1, "maximum": 100 },
        "reitRadar":     { "type": ["integer", "null"], "minimum": 1, "maximum": 100 }
      }
    },
    "ticker": {
      "type": "object",
      "required": [
        "symbol", "name", "exchange", "sector", "industry",
        "price", "volume", "marketCap", "dividendYield", "beta", "rsi",
        "ma200", "ma50", "peRatio", "forwardPE", "priceToBook",
        "week52High", "week52Low", "scores"
      ],
      "additionalProperties": false,
      "properties": {
        "symbol":        { "type": "string", "minLength": 1 },
        "name":          { "type": ["string", "null"] },
        "exchange":      { "type": "string" },
        "sector":        { "type": ["string", "null"] },
        "industry":      { "type": ["string", "null"] },
        "price":         { "type": "number" },
        "volume":        { "type": "integer", "minimum": 0 },
        "marketCap":     { "type": ["integer", "null"], "minimum": 0 },
        "dividendYield": { "type": ["number", "null"], "description": "Percentage (db decimal * 100)" },
        "beta":          { "type": ["number", "null"] },
        "rsi":           { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "ma200":         { "type": ["number", "null"], "minimum": 0 },
        "ma50":          { "type": ["number", "null"], "minimum": 0 },
        "peRatio":       { "type": ["number", "null"] },
        "forwardPE":     { "type": ["number", "null"] },
        "priceToBook":   { "type": ["number", "null"] },
        "week52High":    { "type": ["number", "null"], "minimum": 0 },
        "week52Low":     { "type": ["number", "null"], "minimum": 0 },
        "scores":        { "$ref": "#/$defs/scores" }
      }
    }
  }
}
