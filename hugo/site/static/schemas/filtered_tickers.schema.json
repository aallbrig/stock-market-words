{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "filtered_tickers.schema.json",
  "title": "filtered_tickers.json",
  "description": "All tickers in the database after Pass 1 (price extraction), with latest price snapshot. Generated by hugo_generators.py::generate_filtered_data().",
  "type": "object",
  "required": ["_meta", "generated_at", "date", "total_tickers", "exchanges", "tickers", "statistics"],
  "additionalProperties": false,
  "properties": {
    "_meta": {
      "type": "object",
      "required": ["auto_generated", "generated_by", "generated_at", "warning"],
      "additionalProperties": false,
      "properties": {
        "auto_generated": { "type": "boolean", "const": true },
        "generated_by":   { "type": "string" },
        "generated_at":   { "type": "string", "format": "date-time" },
        "warning":        { "type": "string" }
      }
    },
    "generated_at":  { "type": "string", "format": "date-time" },
    "date":          { "type": "string", "format": "date" },
    "total_tickers": { "type": "integer", "minimum": 0 },
    "exchanges": {
      "type": "object",
      "description": "Ticker count keyed by exchange name",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "tickers": {
      "type": "array",
      "items": { "$ref": "#/$defs/ticker" }
    },
    "statistics": {
      "type": "object",
      "required": ["total_tickers_in_db", "with_price_data", "with_metadata", "by_exchange"],
      "additionalProperties": false,
      "properties": {
        "total_tickers_in_db": { "type": "integer", "minimum": 0 },
        "with_price_data":     { "type": "integer", "minimum": 0 },
        "with_metadata":       { "type": "integer", "minimum": 0 },
        "by_exchange": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    }
  },
  "$defs": {
    "priceData": {
      "type": "object",
      "required": ["date", "price", "volume", "market_cap", "dividend_yield", "beta", "rsi_14", "ma_200"],
      "additionalProperties": false,
      "properties": {
        "date":           { "type": "string", "format": "date" },
        "price":          { "type": ["number", "null"] },
        "volume":         { "type": ["integer", "null"], "minimum": 0 },
        "market_cap":     { "type": ["number", "null"], "minimum": 0, "description": "Raw float from SQLite, not rounded to integer" },
        "dividend_yield": { "type": ["number", "null"], "description": "Raw decimal from SQLite, NOT multiplied by 100 (unlike other files)" },
        "beta":           { "type": ["number", "null"] },
        "rsi_14":         { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "ma_200":         { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "ticker": {
      "type": "object",
      "required": ["symbol", "name", "exchange", "is_etf", "first_seen", "price_data"],
      "additionalProperties": false,
      "properties": {
        "symbol":     { "type": "string", "minLength": 1 },
        "name":       { "type": ["string", "null"] },
        "exchange":   { "type": "string" },
        "is_etf":     { "type": "boolean" },
        "first_seen": { "type": ["string", "null"], "format": "date" },
        "price_data": {
          "oneOf": [
            { "$ref": "#/$defs/priceData" },
            { "type": "null" }
          ]
        }
      }
    }
  }
}
